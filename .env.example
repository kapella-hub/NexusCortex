# NexusCortex Environment Configuration
# For Docker Compose, use service names (api, neo4j, qdrant, redis).
# For local dev, use localhost.

# API
APP_NAME=NexusCortex
DEBUG=false

# Neo4j
# Docker: bolt://neo4j:7687 | Local: bolt://localhost:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_use_a_strong_password
NEO4J_POOL_SIZE=50

# Qdrant
# Docker: qdrant | Local: localhost
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=nexus_memory

# Redis
# Docker: redis://redis:6379/0 | Local: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_KEY=nexus:event_stream
REDIS_BATCH_SIZE=50

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# LLM
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3
LLM_API_KEY=your_api_key_here

# Embedding
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# Authentication (optional — leave blank to disable)
API_KEY=

# CORS
CORS_ORIGINS=["http://localhost:*"]

# RAG Tuning
BOOST_FACTOR=1.5
MEMORY_DECAY_HALF_LIFE_DAYS=90
GRAPH_RELEVANCE_WEIGHT=0.4
RERANK_ENABLED=false
RERANK_CANDIDATES_MULTIPLIER=2

# Rate Limiting
RATE_LIMIT=60/minute

# Content Hashing
CONTENT_HASH_LENGTH=32

# MCP Server
# Docker: http://api:8000 | Local: http://localhost:8000
NEXUS_API_URL=http://api:8000
MCP_HOST=0.0.0.0
MCP_PORT=8080
